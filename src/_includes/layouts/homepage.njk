<section class="section challenges" id="project">
  <div class="container">
    <div class="row">
      <div class="col-12 center">
        <div class="section-title mb-lg">
          <h2 class="uppercase mb-lg">{{challenge.title | safe}}</h2>
          <p>{{challenge.subTitle | safe}}</p>
        </div>
      </div>
      <div class="col-md-6 challenge-col">
        {% for challenge in challenges.challenges_A %}
        <div class="challenge-card">
          <img src="{{challenge.icon}}" />
          <div class="challenge-content">
            <h6>{{challenge.title}}</h6>
            <p>{{challenge.des}}</p>
          </div>
        </div>
        {% endfor %}
      </div>
      <div class="col-md-6 challenge-col">
        {% for challenge in challenges.challenges_B %}
        <div class="challenge-card">
          <img src="{{challenge.icon}}" />
          <div class="challenge-content">
            <h6>{{challenge.title}}</h6>
            <p>{{challenge.des}}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<section class="section mission" id="project">
  <div class="container">
    <div class="row">
      <div class="col-12">
        <div class="section-title">
          <h3>{{mission.title | safe}}</h3>
          <h3>{{mission.main | safe}}</h3>
          <!-- Google Calendar Appointment Scheduling begin -->
          <script
            src="https://calendar.google.com/calendar/scheduling-button-script.js"
            async
          ></script>
          <script defer>
            ;(function () {
              var target = document.currentScript
              window.addEventListener("load", function () {
                calendar.schedulingButton.load({
                  url: "https://calendar.google.com/calendar/appointments/schedules/AcZssZ0vjsn2s4bFmi008CdMUzP-OVemccm239MljgA84LubSCTzS5SNDQMzZNt45JM3Gwzv5yyXOYCU?gv=true",
                  color: "#EB3678",
                  label: "Book a call",
                  target,
                })
              })
            })()
          </script>
          <!-- end Google Calendar Appointment Scheduling -->
        </div>
      </div>
    </div>
  </div>
</section>
<section class="section solutions" id="project">
  <div class="container">
    <div class="section-title center">
      <h2>Solutions</h2>
      {#
      <h6>{{ourSolutions.subTitle | safe}}</h6>
      #}
    </div>
    <div class="grid-container-values">
      {% for solution in solutions.solutions %}
      <div class="grid-item">
        <div class="solution-item">
          <div class="solutions-content">
            <img
              src="{{solution.image}}"
              class="solutions-content-image"
              altText="{{solution.altText}}"
            />
            <p class="solutions-content-title"><b>{{solution.title}}</b></p>
            <h6 class="solutions-content-subtitle">{{solution.subtitle}}</h6>
            <p class="solutions-content-description">
              {{solution.description }}
            </p>
            <a href="/{{hero.managedCloud.link}}">
              <span class="btn-area">
                <span data-text="Explore {{solution.title}}"
                  ><b>Explore {{solution.title}}</b
                  ><img
                    src="/assets/images/right-arrow.svg"
                    class="learn-more-icon"
                /></span>
              </span>
            </a>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endblock %}
